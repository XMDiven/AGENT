# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_documents
RETRIEVAL_TOP_K=7
# Default is similarity; set to mmr to opt into diversity (costs ranking quality, see experiments/retrieval_baseline_2026-06-05.md)
RETRIEVAL_SEARCH_TYPE=similarity
# Only used when RETRIEVAL_SEARCH_TYPE=mmr
RETRIEVAL_FETCH_K=50
RETRIEVAL_LAMBDA_MULT=0.3

# Embedding model service
EMBEDDING_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# Chat model service
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL_ID=moonshot-v1-8k

# Use one compatible API key. Do not commit real secrets.
MOONSHOT_API_KEY=your_api_key_here
# OPENAI_API_KEY=your_api_key_here
